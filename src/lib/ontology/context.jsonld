{
  "@context": {
    "st": "https://stotomas.ai/ontology/",
    "schema": "https://schema.org/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "SummaArticle": "st:SummaArticle",
    "Question": "st:Question",
    "Objection": "st:Objection",
    "Respondeo": "st:Respondeo",
    "Reply": "st:Reply",
    "SedContra": "st:SedContra",
    "topic": { "@id": "st:topic", "@type": "@id" },
    "cites": { "@id": "st:cites", "@type": "@id" },
    "refutes": { "@id": "st:refutes", "@type": "@id" },
    "hasTopic": { "@id": "st:hasTopic", "@type": "@id" },
    "relatedTo": { "@id": "st:relatedTo", "@type": "@id" },
    "narrowerThan": { "@id": "st:narrowerThan", "@type": "@id" },
    "broaderThan": { "@id": "st:broaderThan", "@type": "@id" },
    "hasQuestion": { "@id": "st:hasQuestion", "@type": "@id" },
    "name": "schema:name",
    "description": "schema:description"
  }
}
