generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Traducciones/localizaciones de fuentes (ES/LA) para no re-scrapear ni re-traducir.
model SourceLocalization {
  id        String   @id @default(cuid())
  sourceId  String
  language  String
  title     String
  text      String
  url       String?
  createdAt DateTime @default(now())

  @@unique([sourceId, language])
}

model Debate {
  id          String   @id @default(cuid())
  userId      String
  question    String
  audience    String   @default("graduate")
  context     String?
  objections  Json
  sedContra   String
  respondeo   String
  replies     Json
  application String
  sources     Json
  generatedAt String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([createdAt])
}
